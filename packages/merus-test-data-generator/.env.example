# MerusCase credentials (loaded from GCP Secret Manager; .env is fallback only)
MERUSCASE_EMAIL=
MERUSCASE_PASSWORD=
BROWSERLESS_API_TOKEN=
MERUSCASE_CLIENT_ID=
MERUSCASE_CLIENT_SECRET=
MERUSCASE_ACCESS_TOKEN=

# Paths (non-secret config)
OUTPUT_DIR=output
LOG_DIR=logs
DB_PATH=progress.db

# Audit (auto-generated if not set)
AUDIT_DB_PATH=audit.db
AUDIT_HMAC_KEY=

# FastAPI server (Phase 3)
# API_PORT=5520
# API_HOST=0.0.0.0

# Next.js frontend (Phase 4)
# NEXT_PUBLIC_API_URL=http://localhost:5520
