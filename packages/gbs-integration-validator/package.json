{
  "name": "gbs-integration-validator",
  "version": "1.0.0",
  "description": "Validates connectivity, schemas, and permissions for all GBS platform APIs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@octokit/rest": "^21.1.1",
    "@linear/sdk": "^29.0.0",
    "stripe": "^17.7.0",
    "@google-cloud/resource-manager": "^6.2.0",
    "@google-cloud/billing": "^5.1.0",
    "@slack/web-api": "^7.9.1",
    "ky": "^1.8.1",
    "zod": "^3.24.4",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
