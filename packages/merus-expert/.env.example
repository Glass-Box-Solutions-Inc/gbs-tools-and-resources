# @Developed & Documented by Glass Box Solutions, Inc. using human ingenuity and modern technology
# merus-expert Environment Variables
# Copy to .env and fill in values — NEVER commit .env to git

# ─────────────────────────────────────────────────────
# Required — Service Core
# ─────────────────────────────────────────────────────

# Anthropic Claude API key (required for AI agent)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Secret key for REST API authentication (X-API-Key header)
MERUS_API_KEY=generate_a_strong_random_key_here

# OAuth access token — obtain via OAuth flow scripts (see docs/OAUTH_GUIDE.md)
MERUSCASE_ACCESS_TOKEN=your_oauth_token_here

# Alternative: path to token file (used if ACCESS_TOKEN not set)
MERUSCASE_TOKEN_FILE=.meruscase_token

# ─────────────────────────────────────────────────────
# MerusCase OAuth App Credentials
# ─────────────────────────────────────────────────────
# Needed for OAuth token acquisition scripts (oauth_browser_flow.py, etc.)

MERUSCASE_API_CLIENT_ID=your_client_id
MERUSCASE_API_CLIENT_SECRET=your_client_secret
MERUSCASE_API_BASE_URL=https://api.meruscase.com

# Legacy API token (alternative to OAuth — rarely used)
# MERUSCASE_API_TOKEN=

# ─────────────────────────────────────────────────────
# MerusCase Browser Automation (for matter creation)
# ─────────────────────────────────────────────────────
# Browser automation uses login credentials, not OAuth

MERUSCASE_EMAIL=your_email@firm.com
MERUSCASE_PASSWORD=your_meruscase_password
MERUSCASE_BASE_URL=https://meruscase.com
MERUSCASE_LOGIN_URL=https://meruscase.com/users/login

# Browserless API for cloud headless browser
BROWSERLESS_API_TOKEN=your_browserless_token
BROWSERLESS_ENDPOINT=wss://production-sfo.browserless.io

# Browser mode flags
USE_LOCAL_BROWSER=false
USE_HEADLESS=true
USE_HYBRID_MODE=true

# ─────────────────────────────────────────────────────
# AI / NLP
# ─────────────────────────────────────────────────────

# Google Gemini API key (used by intelligent_parser for NLP)
GOOGLE_API_KEY=your_google_api_key

# ─────────────────────────────────────────────────────
# Service Configuration
# ─────────────────────────────────────────────────────

LOG_LEVEL=INFO
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cache TTL for reference data (billing codes, activity types) in seconds
CACHE_TTL_SECONDS=3600

# ─────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────

# SQLite path (relative to working directory or absolute)
DB_PATH=./knowledge/db/merus_knowledge.db

# ─────────────────────────────────────────────────────
# Security & SOC2 Compliance
# ─────────────────────────────────────────────────────

MERUS_SESSION_TIMEOUT_MIN=30
MERUS_MAX_SESSION_HOURS=8
MERUS_AUDIT_RETENTION_DAYS=90
MERUS_SCREENSHOT_RETENTION_HR=24
MERUS_ENABLE_AUDIT_LOG=true
MERUS_ENCRYPT_SCREENSHOTS=false
USE_SECRET_MANAGER=false

# ─────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────

LOG_FILE=./logs/merus_agent.log
STRUCTURED_LOGGING=true

# ─────────────────────────────────────────────────────
# Advanced Configuration
# ─────────────────────────────────────────────────────

MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
ELEMENT_TIMEOUT_MS=10000
NAVIGATION_TIMEOUT_MS=30000
DRY_RUN_DEFAULT=false

# ─────────────────────────────────────────────────────
# Spectacles Integration (visual analysis / HITL)
# ─────────────────────────────────────────────────────

SPECTICLES_ENABLED=false
SPECTICLES_API_URL=http://localhost:8080
SPECTICLES_API_KEY=your_specticles_api_key
SPECTICLES_TIMEOUT_SECONDS=300
SPECTICLES_REQUIRE_APPROVAL=true
SPECTICLES_USE_FOR_SUBMIT=true
SPECTICLES_VLM_FALLBACK=true
