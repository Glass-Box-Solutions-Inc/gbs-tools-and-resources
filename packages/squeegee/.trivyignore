# Trivy ignore list for Squeegee container
# These are in Node.js/npm system packages, not in our application code.
# They are only present during `npm install` (build stage) and are not
# exploitable at runtime since npm is not used after container startup.

# cross-spawn: ReDoS in command parsing (npm internal)
CVE-2024-21538

# glob: command injection via filenames (npm internal)
CVE-2025-64756

# minimatch: ReDoS via glob patterns (npm internal)
CVE-2026-26996
CVE-2026-27903
CVE-2026-27904

# tar: symlink/hardlink path traversal (npm internal, not used at runtime)
CVE-2026-23745
CVE-2026-23950
CVE-2026-24842
CVE-2026-26960
CVE-2026-29786
