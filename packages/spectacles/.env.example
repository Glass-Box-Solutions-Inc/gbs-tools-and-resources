# =============================================================================
# Spectacles Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# CORE APPLICATION
# =============================================================================
ENVIRONMENT=development          # development | production
DEBUG=true                       # Enable debug logging
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# GCP Configuration
# =============================================================================
GCP_PROJECT_ID=your-gcp-project-id

# =============================================================================
# BROWSER AUTOMATION (Browserless.io)
# =============================================================================
# Get token from: https://www.browserless.io/
BROWSERLESS_API_TOKEN=your-browserless-token
BROWSERLESS_ENDPOINT=wss://production-sfo.browserless.io
USE_LOCAL_BROWSER=false          # Set to true to use local Playwright instead

# =============================================================================
# SLACK INTEGRATION (Human-in-the-Loop)
# =============================================================================
# Create app at: https://api.slack.com/apps

# Bot OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token

# Channel for approval requests
SLACK_APPROVAL_CHANNEL=#spectacles-approvals

# Signing secret for webhook verification
SLACK_SIGNING_SECRET=

# Webhook URLs (alternative to OAuth - one-way notifications)
SLACK_WEBHOOK_MAIN=              # Main channel webhook
SLACK_WEBHOOK_ALEX=              # Alex's direct webhook
SLACK_WEBHOOK_BRIAN=             # Brian's direct webhook
SLACK_WEBHOOK_SOCIAL=            # Social channel webhook

# =============================================================================
# AI / VISION & REASONING (Gemini 2.5 Flash + 3.0)
# =============================================================================
# Get key from: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-gemini-api-key

# Vision model - fast, cheap, excellent multimodal understanding
VLM_MODEL=gemini-2.5-flash
VLM_TIMEOUT_SECONDS=30

# Reasoning model - strategic planning, complex decision-making (Gemini 3.0/3.1)
REASONING_MODEL=gemini-3.0
REASONING_TIMEOUT_SECONDS=60

# =============================================================================
# VECTOR DATABASE (Pinecone - Long-term Memory)
# =============================================================================
# Get key from: https://www.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=spectacles-memory
PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# DATABASE
# =============================================================================
# SQLite path for local development
DB_PATH=./spectacles.db

# PostgreSQL for production (optional)
# DATABASE_URL=postgresql://user:pass@host:5432/spectacles

# =============================================================================
# SECURITY
# =============================================================================
# Fernet encryption key for session data
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key

# Secret key for signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
SESSION_TIMEOUT_MIN=30
MAX_SESSION_HOURS=8

# =============================================================================
# SCREENSHOT MANAGEMENT
# =============================================================================
SCREENSHOT_RETENTION_HR=24
ENCRYPT_SCREENSHOTS=false
SCREENSHOT_DIR=./screenshots

# =============================================================================
# AUDIT & COMPLIANCE
# =============================================================================
AUDIT_RETENTION_DAYS=90

# =============================================================================
# BROWSER TIMEOUTS & RETRIES
# =============================================================================
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
ELEMENT_TIMEOUT_MS=10000
NAVIGATION_TIMEOUT_MS=30000

# =============================================================================
# HITL SETTINGS
# =============================================================================
HITL_APPROVAL_TIMEOUT_SECONDS=300
HITL_DEFAULT_REQUIRE_APPROVAL=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD_SECONDS=60

# =============================================================================
# PERCEPTION SETTINGS
# =============================================================================
PERCEPTION_MODE=hybrid           # per_action | continuous | hybrid | on_demand
PERCEPTION_INTERVAL_MS=2000      # For continuous mode
VLM_BUDGET_PER_TASK=10           # Max VLM calls per task
DOM_CONFIDENCE_THRESHOLD=0.7     # Below this, use VLM
PERCEPTION_CACHE_TTL_MS=1000     # DOM cache validity
DETECT_PAGE_CHANGES=true

# =============================================================================
# DESKTOP AUTOMATION (VM deployment only)
# =============================================================================
ENABLE_DESKTOP_AUTOMATION=false  # Requires display access
PYAUTOGUI_FAILSAFE=true          # Emergency stop at corners
PYAUTOGUI_PAUSE=0.1              # Pause between actions
OCR_LANGUAGE=en

# =============================================================================
# FILE SYSTEM OPERATIONS (disabled by default for security)
# =============================================================================
ENABLE_FILE_OPERATIONS=false
ALLOWED_FILE_PATHS=~/Documents,~/Downloads,/tmp/spectacles
MAX_FILE_SIZE_MB=100
ALLOW_FILE_DELETE=false          # Extra protection
