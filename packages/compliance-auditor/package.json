{
  "name": "compliance-auditor",
  "version": "1.0.0",
  "description": "SOC2 + HIPAA compliance scanning for GBS repositories",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@prisma/client": "^6.9.0",
    "@octokit/rest": "^21.1.1",
    "zod": "^3.24.4",
    "ky": "^1.8.1",
    "pino": "^9.6.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "vitest": "^3.1.4",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
